{
  "manifest_version": 3,
  "name": "AI Universal Clipboard",
  "version": "1.0.0",
  "description": "A Chrome extension clipboard app for managing text and image clips with a side panel interface.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage"
  ],
  "action": {
    "default_title": "Open Clipboard"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}